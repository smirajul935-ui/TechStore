<resources>
    <style name="Theme.TechStore" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/accent_purple</item>
        <item name="colorPrimaryVariant">@color/accent_cyan</item>
        <item name="colorOnPrimary">@color/text_white</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:textColor">@color/text_white</item>
    </style>
    <style name="Theme.TechStore.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
    </style>
</resources>
